{
  "name": "@musicians/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "seed": "tsx src/seed.ts",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:push": "drizzle-kit push",
    "e2e:db-setup": "tsx src/dbSetupE2E.ts",
    "e2e:server": "NODE_ENV=test PORT=3002 DATABASE_URL=postgresql://postgres:postgres@localhost:5432/musicians_test tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@trpc/server": "^11.16.0",
    "bcrypt": "^6.0.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.3",
    "jose": "^6.1.3",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^24.10.1",
    "@vitest/ui": "^4.1.4",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "vitest": "^4.1.4"
  }
}
