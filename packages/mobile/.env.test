# Maestro e2e (MUS-71): point the mobile bundle at the test server on
# port 3002 instead of the dev server on 3001. Loaded by Expo when
# `pnpm e2e:mobile` is invoked from the repo root via `--env-file`.
# Stays committed because it's deterministic + non-secret config.
EXPO_PUBLIC_API_URL=http://localhost:3002
